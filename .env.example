# Database
DATABASE_URL=postgresql+asyncpg://jobscraper:jobscraper@localhost:5432/jobscraper

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Embedding model (local, no API key needed by default)
# Options: BAAI/bge-base-en-v1.5 | all-MiniLM-L6-v2
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768

# Admin API key (used to protect /admin/* endpoints)
ADMIN_KEY=change-me-to-a-secret

# Optional: Claude API for match explanations (Phase 4+)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: proxy for scraping LinkedIn/Glassdoor (Phase 2+)
# SCRAPER_PROXY_URL=http://user:pass@proxy-host:port

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
